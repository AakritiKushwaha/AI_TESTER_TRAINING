<?xml version="1.0" encoding="UTF-8"?>
<Configuration packages="org.apache.logging.log4j.core">
    <Properties>
        <Property name="log.dir">target/logs</Property>
        <Property name="log.pattern">%d{yyyy-MM-dd HH:mm:ss} [%t] %-5p %c{1} - %m%n</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${log.pattern}"/>
        </Console>

        <!-- File Appender for All Logs -->
        <File name="FileAppender" fileName="${log.dir}/test-execution.log">
            <PatternLayout pattern="${log.pattern}"/>
        </File>

        <!-- File Appender for Info Logs -->
        <File name="InfoAppender" fileName="${log.dir}/info.log">
            <PatternLayout pattern="${log.pattern}"/>
        </File>

        <!-- File Appender for Error Logs -->
        <File name="ErrorAppender" fileName="${log.dir}/error.log">
            <PatternLayout pattern="${log.pattern}"/>
        </File>

        <!-- Rolling File Appender -->
        <RollingFile name="RollingFileAppender" 
                     fileName="${log.dir}/rolling-test.log"
                     filePattern="${log.dir}/rolling-test-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${log.pattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Root>

        <!-- REST Assured Loggers -->
        <Logger name="io.restassured" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Test Class Loggers -->
        <Logger name="com.restassured" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Custom Loggers for Services and Tests -->
        <Logger name="com.restassured.service" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <Logger name="com.restassured.tests" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Configuration Logger -->
        <Logger name="com.restassured.config" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="InfoAppender"/>
        </Logger>
    </Loggers>
</Configuration>
